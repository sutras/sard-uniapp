{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "sourceMap": true,
    "lib": ["esnext", "dom"],
    "types": [
      "@dcloudio/types",
      "sard-uniapp/global",
      "vite/client",
      "./env.d.ts"
    ],
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "packages/**/*",
    "packages/docs/.vitepress/**/*",
    "scripts/**/*",
    "./*.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/cache/**",
    "docs/**",
    "**/node_modules/**",
    "**/uni_modules/**"
  ]
}
